LIBRARY IEEE;
USE IEEE.STD_LOGIC_1164.ALL;
USE IEEE.NUMERIC_STD.ALL;

entity ingredient_fsm is
    Port (
        clk           : in  STD_LOGIC;
        reset         : in  STD_LOGIC;
        BTNC          : in  STD_LOGIC;  -- button press
		
        -- Ingredient input (what player is trying to pick up)
        input_item    : in  STD_LOGIC_VECTOR(3 downto 0);

        -- Outputs (for debugging / display)
        held_out      : out STD_LOGIC_VECTOR(3 downto 0);
        counter_out   : out STD_LOGIC_VECTOR(3 downto 0)
    );
end ingredient_fsm;

architecture Behavioral of ingredient_fsm is

    -- Ingredient encoding
    constant NONE       : STD_LOGIC_VECTOR(3 downto 0) := "0000";
    constant BUN        : STD_LOGIC_VECTOR(3 downto 0) := "0001";
    constant MEAT       : STD_LOGIC_VECTOR(3 downto 0) := "0010";
    constant POTATO     : STD_LOGIC_VECTOR(3 downto 0) := "0011";
    constant HAMBURGER  : STD_LOGIC_VECTOR(3 downto 0) := "0100";
    constant FRIES      : STD_LOGIC_VECTOR(3 downto 0) := "0101";
    constant FRYER      : STD_LOGIC_VECTOR(3 downto 0) := "0111";
    constant CHEESE     : STD_LOGIC_VECTOR(3 downto 0) := "1000";
    constant MEATCHEESE : STD_LOGIC_VECTOR(3 downto 0) := "1001";
    constant BUNCHEESE  : STD_LOGIC_VECTOR(3 downto 0) := "1010";
    constant BURGER     : STD_LOGIC_VECTOR(3 downto 0) := "1011";

    -- FSM states
    type state_t is (EMPTY_HAND, HOLDING);
    signal state : state_t := EMPTY_HAND;

    -- Internal storage
    signal held_item    : STD_LOGIC_VECTOR(3 downto 0) := NONE;
    signal counter_item : STD_LOGIC_VECTOR(3 downto 0) := NONE;

    -- Combine function
    function combine(a, b : STD_LOGIC_VECTOR(3 downto 0))
        return STD_LOGIC_VECTOR is
    begin
        -- BUN + MEAT = HAMBURGER
        if (a = BUN and b = MEAT) or (a = MEAT and b = BUN) then
            return BURGER;
        
        -- MEAT + CHEESE = MEATCHEESE
        if (a = CHEESE and b = MEAT) or (a = MEAT and b = CHEESE) then
            return MEATCHEESE;

        -- BUN + CHEESE = BUNCHEESE
        if (a = BUN and b = CHEESE) or (a = CHEESE and b = BUN) then
            return BUNCHEESE;

        -- MEATCHEESE + BUN = BURGER
        if (a = BUN and b = MEATCHEESE) or (a = MEATCHEESE and b = BUN) then
            return BURGER;

        -- BUNCHEESE + MEAT = BURGER
        if (a = BUNCHEESE and b = MEAT) or (a = MEAT and b = BUNCHEESE) then
            return BURGER;

        -- POTATO + FRYER = FRIES
        elsif (a = POTATO and b = FRYER) or (a = FRYER and b = POTATO) then
            return FRIES;

        else
            return NONE; -- invalid combo
        end if;
    end function;

begin

    process(clk, reset)
        variable result : STD_LOGIC_VECTOR(3 downto 0);
    begin
        if reset = '1' then
            state        <= EMPTY_HAND;
            held_item    <= NONE;
            counter_item <= NONE;

        elsif rising_edge(clk) then
-- finitie state machine with two states
            case state is

                -- =========================
                when EMPTY_HAND =>
                -- =========================
                    if BTNC = '1' then
                        if input_item /= NONE then
                            held_item <= input_item;
                            state <= HOLDING;
                        elsif counter_item /= NONE then
                            -- pick up from counter
                            held_item <= counter_item;
                            counter_item <= NONE;
                            state <= HOLDING;
                        end if;
                    end if;

                -- =========================
                when HOLDING =>
                -- =========================
                    if BTNC = '1' then

                        if counter_item = NONE then
                            -- Place item
                            counter_item <= held_item;
                            held_item <= NONE;
                            state <= EMPTY_HAND;

                        else
                            -- Try to combine
                            result := combine(held_item, counter_item);

                            if result /= NONE then
                                counter_item <= result;
                                held_item <= NONE;
                                state <= EMPTY_HAND;
                            else
                                -- Invalid combo: do nothing (or could swap/drop)
                            end if;

                        end if;

                    end if;

            end case;
        end if;
    end process;

    -- Outputs
    held_out    <= held_item;
    counter_out <= counter_item;

end Behavioral;
